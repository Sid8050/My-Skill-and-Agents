{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": ["opencode-go-zen"],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "provider": {
    "opencode-go-zen": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenCode Go Zen (via Proxy)",
      "options": {
        "baseURL": "http://localhost:8320",
        "apiKey": "sk-placeholder",
        "timeout": 300000
      },
      "models": {
        "deepseek-v4-pro": { "id": "deepseek-v4-pro", "limit": { "context": 300000, "output": 32768 } },
        "deepseek-v4-flash": { "id": "deepseek-v4-flash", "limit": { "context": 300000, "output": 16384 } },
        "glm-5.2": { "id": "glm-5.2", "limit": { "context": 300000, "output": 32768 } },
        "glm-5.1": { "id": "glm-5.1", "limit": { "context": 300000, "output": 32768 } },
        "glm-5": { "id": "glm-5", "limit": { "context": 300000, "output": 16384 } },
        "hy3-preview": { "id": "hy3-preview", "limit": { "context": 300000, "output": 16384 } },
        "kimi-k2.7-code": { "id": "kimi-k2.7-code", "limit": { "context": 300000, "output": 32768 } },
        "kimi-k2.6": { "id": "kimi-k2.6", "limit": { "context": 300000, "output": 32768 } },
        "kimi-k2.5": { "id": "kimi-k2.5", "limit": { "context": 300000, "output": 16384 } },
        "mimo-v2-pro": { "id": "mimo-v2-pro", "limit": { "context": 300000, "output": 32768 } },
        "mimo-v2-omni": { "id": "mimo-v2-omni", "limit": { "context": 300000, "output": 16384 } },
        "mimo-v2.5": { "id": "mimo-v2.5", "limit": { "context": 300000, "output": 16384 } },
        "mimo-v2.5-pro": { "id": "mimo-v2.5-pro", "limit": { "context": 300000, "output": 32768 } },
        "minimax-m3": { "id": "minimax-m3", "limit": { "context": 300000, "output": 16384 } },
        "minimax-m2.7": { "id": "minimax-m2.7", "limit": { "context": 300000, "output": 16384 } },
        "minimax-m2.5": { "id": "minimax-m2.5", "limit": { "context": 300000, "output": 16384 } },
        "qwen3.7-max": { "id": "qwen3.7-max", "limit": { "context": 300000, "output": 32768 } },
        "qwen3.7-plus": { "id": "qwen3.7-plus", "limit": { "context": 300000, "output": 16384 } },
        "qwen3.6-plus": { "id": "qwen3.6-plus", "limit": { "context": 300000, "output": 16384 } },
        "qwen3.5-plus": { "id": "qwen3.5-plus", "limit": { "context": 300000, "output": 16384 } }
      }
    }
  },

  // Custom agents (vitruvius, da-vinci, argus) are defined in agents/*.md.
  // Their mode, model, temperature and permission live in the .md frontmatter
  // to keep a single source of truth. Do not redefine them here.
  "agent": {
    "backend": { "model": "opencode-go-zen/deepseek-v4-pro" },
    "frontend": { "model": "opencode-go-zen/kimi-k2.7-code" },
    "think-deep": { "model": "opencode-go-zen/glm-5.2" }
  }
}
