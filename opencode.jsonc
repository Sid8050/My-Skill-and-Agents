{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": ["opencode-go-zen"],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "provider": {
    "opencode-go-zen": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenCode Go Zen (via Proxy)",
      "options": {
        "baseURL": "http://localhost:8320",
        "apiKey": "sk-placeholder",
        "timeout": 300000
      },
      "models": {
        "deepseek-v4-pro": { "id": "deepseek-v4-pro", "limit": { "context": 300000, "output": 32768 } },
        "deepseek-v4-flash": { "id": "deepseek-v4-flash", "limit": { "context": 300000, "output": 16384 } },
        "glm-5.1": { "id": "glm-5.1", "limit": { "context": 300000, "output": 32768 } },
        "glm-5": { "id": "glm-5", "limit": { "context": 300000, "output": 16384 } },
        "kimi-k2.6": { "id": "kimi-k2.6", "limit": { "context": 300000, "output": 32768 } },
        "kimi-k2.5": { "id": "kimi-k2.5", "limit": { "context": 300000, "output": 16384 } },
        "mimo-v2.5": { "id": "mimo-v2.5", "limit": { "context": 300000, "output": 16384 } },
        "mimo-v2.5-pro": { "id": "mimo-v2.5-pro", "limit": { "context": 300000, "output": 32768 } },
        "minimax-m3": { "id": "minimax-m3", "limit": { "context": 300000, "output": 16384 } },
        "minimax-m2.7": { "id": "minimax-m2.7", "limit": { "context": 300000, "output": 16384 } },
        "minimax-m2.5": { "id": "minimax-m2.5", "limit": { "context": 300000, "output": 16384 } },
        "qwen3.7-max": { "id": "qwen3.7-max", "limit": { "context": 300000, "output": 32768 } },
        "qwen3.7-plus": { "id": "qwen3.7-plus", "limit": { "context": 300000, "output": 16384 } },
        "qwen3.6-plus": { "id": "qwen3.6-plus", "limit": { "context": 300000, "output": 16384 } }
      }
    }
  },
  "agent": {
    "backend": { "model": "opencode-go-zen/deepseek-v4-pro" },
    "frontend": { "model": "opencode-go-zen/kimi-k2.6" },
    "think-deep": { "model": "opencode-go-zen/glm-5.1" },
    "vitruvius": {
      "mode": "all",
      "model": "opencode-go-zen/deepseek-v4-pro",
      "temperature": 0.1,
      "permission": {
        "edit": {
          "architect/**": "allow",
          "plans/**": "allow",
          "*": "deny"
        },
        "bash": "deny",
        "skill": {
          "zoom-out": "allow",
          "improve-codebase-architecture": "allow",
          "to-prd": "allow",
          "grill-with-docs": "allow",
          "write-a-skill": "allow",
          "teach": "allow",
          "handoff": "allow",
          "triage": "allow",
          "diagnose": "allow",
          "improve": "allow",
          "torpathy": "allow",
          "*": "deny"
        }
      }
    },
    "da-vinci": {
      "mode": "primary",
      "model": "opencode-go-zen/deepseek-v4-pro",
      "temperature": 0.1,
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "task": {
          "vitruvius": "allow",
          "argus": "allow"
        },
        "skill": {
          "caveman": "allow",
          "tdd": "allow",
          "diagnose": "allow",
          "prototype": "allow",
          "to-issues": "allow",
          "grill-me": "allow",
          "handoff": "allow",
          "teach": "allow",
          "git-guardrails-claude-code": "allow",
          "setup-pre-commit": "allow",
          "zoom-out": "allow",
          "improve": "allow",
          "*": "deny"
        }
      }
    },
    "argus": {
      "mode": "subagent",
      "model": "opencode-go-zen/kimi-k2.6",
      "temperature": 0.05,
      "permission": {
        "edit": {
          "**/*.test.*": "allow",
          "**/*.spec.*": "allow",
          "**/__tests__/**": "allow",
          "**/tests/**": "allow",
          "*": "deny"
        },
        "bash": {
          "npm test*": "allow",
          "npm run test*": "allow",
          "npx vitest*": "allow",
          "npx jest*": "allow",
          "pytest*": "allow",
          "go test*": "allow",
          "cargo test*": "allow",
          "npm run lint*": "allow",
          "npm run typecheck*": "allow",
          "npx tsc*": "allow",
          "*": "deny"
        },
        "skill": {
          "diagnose": "allow",
          "tdd": "allow",
          "review": "allow",
          "to-issues": "allow",
          "caveman": "allow",
          "handoff": "allow",
          "zoom-out": "allow",
          "improve": "allow",
          "*": "deny"
        }
      }
    }
  }
}
